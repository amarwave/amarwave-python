# AmarWave Python SDK — Environment Variables
# All variables are optional; hardcoded defaults are shown.

# WebSocket server hostname
AMARWAVE_WS_HOST=localhost

# WebSocket plain-text port
AMARWAVE_WS_PORT=3001

# WebSocket TLS port
AMARWAVE_WSS_PORT=443

# Set to "true" to connect with wss://
AMARWAVE_WS_TLS=false

# WebSocket upgrade path (change only if you customised the server route)
AMARWAVE_WS_PATH=/ws

# HTTP API hostname for publishing events (defaults to WS_HOST)
# AMARWAVE_API_HOST=localhost

# HTTP API port
AMARWAVE_API_PORT=8000

# HTTP API trigger path (change only if you customised the server route)
AMARWAVE_API_PATH=/api/v1/trigger

# Server-side channel authentication endpoint (for private/presence channels)
# AMARWAVE_AUTH_ENDPOINT=http://localhost:8000/broadcasting/auth
